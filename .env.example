# ──────────────────────────────────────────────
# PDD Moldova – Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
POSTGRES_PASSWORD=pdd_secret
# NOTE: Replace ${POSTGRES_PASSWORD} below with the actual password value
# if your .env parser does not support variable interpolation.
DATABASE_URL=postgresql://pdd:${POSTGRES_PASSWORD}@db:5432/pdd_moldova?schema=public

# ── Redis / BullMQ ────────────────────────────
REDIS_URL=redis://redis:6379

# ── Telegram ──────────────────────────────────
BOT_TOKEN=your-telegram-bot-token
WEBAPP_URL=https://your-domain.com
TELEGRAM_BOT_USERNAME=pdd_moldova_bot

# ── JWT / Auth ────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# ── S3 / Object Storage ──────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pdd-assets
S3_REGION=us-east-1

# ── API ───────────────────────────────────────
API_PORT=3001

# ── WebApp (Next.js) ─────────────────────────
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=${TELEGRAM_BOT_USERNAME}

# ── Admin Panel ───────────────────────────────
ADMIN_PORT=3002

# ── Workers ───────────────────────────────────
PARSER_CONCURRENCY=2
RECONCILER_CONCURRENCY=1

# ── OCR (optional) ───────────────────────────
TESSERACT_LANG=ron+rus

# ── Node ──────────────────────────────────────
NODE_ENV=development
