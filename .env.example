# ──────────────────────────────────────────────
# PDD Moldova – Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://pdd:pdd_secret@db:5432/pdd_moldova?schema=public

# ── Redis / BullMQ ────────────────────────────
REDIS_URL=redis://redis:6379

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBAPP_URL=https://your-domain.com

# ── JWT / Auth ────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# ── S3 / Object Storage ──────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pdd-assets
S3_REGION=us-east-1

# ── API ───────────────────────────────────────
API_PORT=3001
API_PREFIX=/api

# ── WebApp (Next.js) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=pdd_moldova_bot

# ── Admin Panel ───────────────────────────────
ADMIN_PORT=3002

# ── Workers ───────────────────────────────────
PARSER_CONCURRENCY=2
RECONCILER_CONCURRENCY=1

# ── OCR (optional) ───────────────────────────
TESSERACT_LANG=ron+rus

# ── Node ──────────────────────────────────────
NODE_ENV=development
